---
interface GalleryItem {
  image: string;
  alt: string;
  order: number;
}

interface Props {
  title: string;
  subtitle: string;
  items: GalleryItem[];
}

const { title, subtitle, items } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="gallery" class="py-[60px] lg:py-[100px] px-4 lg:px-6 bg-light-bg text-center">
  <h2 class="font-heading text-[2rem] lg:text-[2.4rem] font-bold text-brand-dark mb-3">{title}</h2>
  <p class="text-[1.1rem] font-light text-brand-rose mb-12">{subtitle}</p>
  <div class="max-w-[1100px] mx-auto grid grid-cols-2 lg:grid-cols-3 gap-[10px] lg:gap-5">
    {items.map((item) => (
      <div class="rounded-xl overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.08)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_12px_32px_rgba(163,88,109,0.2)]">
        <img src={`${base}/${item.image}`} alt={item.alt} class="w-full h-[180px] lg:h-[280px] object-cover block" />
      </div>
    ))}
  </div>
</section>
