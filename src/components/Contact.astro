---
interface Props {
  title: string;
  text: string;
  cta: string;
  email: string;
}

const { title, text, cta, email } = Astro.props;
const mailtoHref = `mailto:${email}?subject=Doresc%20s%C4%83%20comand%20un%20tablou`;
---

<section id="contact" class="py-[60px] lg:py-[100px] px-5 lg:px-6 bg-gradient-to-br from-lavender to-blush text-center">
  <div class="max-w-[600px] mx-auto">
    <h2 class="font-heading text-[2rem] lg:text-[2.4rem] font-bold text-brand-dark mb-3">{title}</h2>
    <p class="text-[1.1rem] font-light text-brand-dark mb-8 leading-[1.7]">{text}</p>
    <a
      href={mailtoHref}
      class="inline-block px-9 py-[14px] rounded-full bg-deep-rose text-white font-bold tracking-wide transition-all duration-300 hover:bg-brand-rose hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(163,88,109,0.35)]"
    >
      {cta}
    </a>
    <p class="mt-5 text-base font-light text-brand-dark">{email}</p>
  </div>
</section>
