---
interface Props {
  businessName: string;
  email: string;
}

const { businessName, email } = Astro.props;
const mailtoHref = `mailto:${email}?subject=Doresc%20s%C4%83%20comand%20un%20tablou`;
---

<!-- Navigation -->
<nav class="fixed top-0 left-0 w-full flex items-center justify-between px-5 lg:px-12 py-[14px] lg:py-[18px] bg-white/90 backdrop-blur-sm z-[1100] shadow-sm">
  <a href="#hero" class="font-heading text-[1.6rem] font-bold text-deep-rose">{businessName}</a>
  <ul class="nav-links flex gap-8 list-none max-lg:hidden">
    <li><a href="#about" class="text-[0.95rem] text-brand-dark transition-colors duration-300 hover:text-deep-rose">Despre</a></li>
    <li><a href="#gallery" class="text-[0.95rem] text-brand-dark transition-colors duration-300 hover:text-deep-rose">Galerie</a></li>
    <li><a href="#how-it-works" class="text-[0.95rem] text-brand-dark transition-colors duration-300 hover:text-deep-rose">Cum funcționează</a></li>
    <li><a href="#pricing" class="text-[0.95rem] text-brand-dark transition-colors duration-300 hover:text-deep-rose">Prețuri</a></li>
    <li><a href="#reviews" class="text-[0.95rem] text-brand-dark transition-colors duration-300 hover:text-deep-rose">Recenzii</a></li>
    <li><a href="#contact" class="text-[0.95rem] text-brand-dark transition-colors duration-300 hover:text-deep-rose">Contact</a></li>
  </ul>
  <a href={mailtoHref} class="inline-block max-lg:hidden px-6 py-[10px] rounded-full bg-deep-rose text-white text-[0.9rem] font-bold transition-all duration-300 hover:bg-brand-rose hover:-translate-y-px">Comandă acum</a>
  <button class="hamburger flex lg:hidden" id="hamburger-btn" aria-label="Deschide meniul">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- Mobile Navigation Overlay -->
<div class="mobile-nav fixed inset-0 bg-[rgba(253,248,244,0.98)] backdrop-blur-md z-[1050] flex-col items-center justify-center gap-3 opacity-0 -translate-y-4 transition-all duration-300 pointer-events-none" id="mobile-nav">
  <ul class="flex flex-col items-center gap-2 list-none mb-6">
    <li><a href="#about" class="font-heading text-[2rem] font-semibold text-brand-dark hover:text-deep-rose transition-colors duration-200">Despre</a></li>
    <li><a href="#gallery" class="font-heading text-[2rem] font-semibold text-brand-dark hover:text-deep-rose transition-colors duration-200">Galerie</a></li>
    <li><a href="#how-it-works" class="font-heading text-[2rem] font-semibold text-brand-dark hover:text-deep-rose transition-colors duration-200">Cum funcționează</a></li>
    <li><a href="#pricing" class="font-heading text-[2rem] font-semibold text-brand-dark hover:text-deep-rose transition-colors duration-200">Prețuri</a></li>
    <li><a href="#reviews" class="font-heading text-[2rem] font-semibold text-brand-dark hover:text-deep-rose transition-colors duration-200">Recenzii</a></li>
    <li><a href="#contact" class="font-heading text-[2rem] font-semibold text-brand-dark hover:text-deep-rose transition-colors duration-200">Contact</a></li>
  </ul>
  <a href={mailtoHref} class="inline-block px-11 py-[14px] rounded-full bg-deep-rose text-white text-[1.05rem] font-bold transition-all duration-300 hover:bg-brand-rose">Comandă acum</a>
</div>
