---
interface Props {
  title: string;
  paragraphs: string[];
  image: string;
  imageAlt: string;
}

const { title, paragraphs, image, imageAlt } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="about" class="py-[60px] lg:py-[100px] px-5 lg:px-6 bg-white">
  <div class="max-w-[1100px] mx-auto flex flex-col lg:flex-row items-center gap-7 lg:gap-[60px]">
    <div class="w-full lg:flex-none lg:w-[400px] rounded-2xl overflow-hidden shadow-[0_12px_40px_rgba(163,88,109,0.15)]">
      <img src={`${base}/${image}`} alt={imageAlt} class="w-full h-[280px] lg:h-[500px] object-cover" />
    </div>
    <div class="flex-1">
      <h2 class="font-heading text-[1.8rem] lg:text-[2.4rem] font-bold text-brand-dark mb-5">{title}</h2>
      {paragraphs.map((p) => (
        <p class="text-[1.05rem] font-light leading-[1.8] text-brand-dark mb-4" set:html={p} />
      ))}
    </div>
  </div>
</section>
